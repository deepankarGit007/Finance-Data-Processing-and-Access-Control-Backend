# Copy this file to .env and fill in your values
# The app reads these via appsettings.json / environment variables

ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL connection
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=finance_db;Username=finance_user;Password=finance_pass

# JWT Settings (minimum 32 characters for the secret key)
Jwt__SecretKey=REPLACE_WITH_A_STRONG_RANDOM_32_CHAR_SECRET
Jwt__Issuer=FinanceBackend
Jwt__Audience=FinanceBackendUsers
Jwt__ExpiryMinutes=60
